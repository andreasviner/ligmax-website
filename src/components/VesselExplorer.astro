---
---

<div class="explorer" data-reveal>
  <div class="stage-card">
    <div class="stage" id="stage">
      <canvas id="explorer-canvas"></canvas>
      <div class="stage-overlay" id="stage-status">Loading model&hellip;</div>
      <button class="stage-reset" id="reset-view" type="button" title="Reset view">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 12a9 9 0 1 0 3-6.7" />
          <path d="M3 4v5h5" />
        </svg>
        Reset view
      </button>
    </div>
    <p class="stage-hint" aria-hidden="true">Drag to rotate &middot; scroll to zoom &middot; click a part to identify it</p>
  </div>

  <aside class="panel">
    <span class="panel-eyebrow">Part inspector</span>
    <h2 class="panel-title" id="part-title">No part selected</h2>
    <p class="panel-description" id="part-description">
      Click any component of the vessel to learn what it does — or highlight a whole system below.
    </p>

    <div class="panel-divider"></div>

    <h3 class="panel-list-heading">Highlight a system</h3>
    <div class="chip-row" id="chip-row"></div>
  </aside>
</div>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
  import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';
  import partInfo from '../data/part-info.json';

  const STRUCTURAL_TITLE = 'Structural component';
  const STRUCTURAL_TEXT =
    'A structural element of the vessel — the mounts, brackets and fairings that tie the main systems together.';
  const DEFAULT_TITLE = 'No part selected';
  const DEFAULT_TEXT =
    'Click any component of the vessel to learn what it does — or highlight a whole system below.';

  const SYSTEMS = {
    sensors: {
      label: 'Sensor package',
      description:
        'The complete perception suite — both cameras, front and rear lidars with the stabilising gimbal, the GNSS antenna and the water-level sensors.',
      parts: [
        'Sphere',
        'Sphere.001',
        'Body1',
        'Body1.008',
        'Body1.007',
        'LidarMount',
        'M1',
        'M2',
        'Body1.009',
        'Gimbaswingarm',
        'Body5',
        'Cylinder.001',
        'Cylinder.002',
      ],
    },
    cameras: {
      label: 'Cameras',
      description:
        'The two 220° wide-angle cameras covering the forward arc. They add what lidar cannot see — colour — classifying detected objects such as red and green channel markers.',
      parts: ['Sphere', 'Sphere.001'],
    },
    lidars: {
      label: 'Lidars',
      description:
        'Both 360° 2D lidars: the gimbal-stabilised unit at the bow and the rear-facing unit aft, together covering every bearing around the vessel.',
      parts: ['Body1', 'Body1.008', 'Body1.007', 'LidarMount'],
    },
    water: {
      label: 'Water-level sensors',
      description:
        'The ultrasonic water-level detectors, giving the control system continuous buoyancy feedback and early warning of water ingress.',
      parts: ['Cylinder.001', 'Cylinder.002'],
    },
    propulsion: {
      label: 'Propulsion',
      description:
        'The two main thrusters and their propellers, plus the lateral stern thruster used for station-keeping and docking. Differential thrust between the mains steers the vessel.',
      parts: ['Body72', 'Body73', 'propeller_3', 'propeller_3 (1)', 'Body1.006', '2Back (1)', '2Back (2)'],
    },
    rolltrim: {
      label: 'Roll-trim mechanism',
      description:
        'The slide mechanisms and extension arms that shift the outriggers vertically, adjusting the righting moment to keep the platform level in waves.',
      parts: ['Body1.013', 'Body1.014', 'Body2.004', 'Body2.005'],
    },
  };

  // three.js sanitises glTF node names on load (spaces -> underscores; . : / [ ] stripped),
  // so every name comparison goes through the same canonical form, and we prefer the
  // original glTF name that GLTFLoader preserves in userData.name.
  const sanitize = (name) => name.replace(/\s/g, '_').replace(/[\[\]\.:\/]/g, '');
  const infoByCanonical = {};
  for (const [key, value] of Object.entries(partInfo)) infoByCanonical[sanitize(key)] = value;

  const stage = document.getElementById('stage');
  const canvas = document.getElementById('explorer-canvas');
  const statusEl = document.getElementById('stage-status');
  const resetBtn = document.getElementById('reset-view');
  const titleEl = document.getElementById('part-title');
  const descriptionEl = document.getElementById('part-description');
  const chipRow = document.getElementById('chip-row');

  if (stage && canvas) {
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const scene = new THREE.Scene();
    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

    const camera = new THREE.PerspectiveCamera(30, 1, 0.01, 100);
    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.08;

    const hemi = new THREE.HemisphereLight(0xffffff, 0xdfe5f0, 0.5);
    scene.add(hemi);

    /** @type {THREE.Mesh[]} */
    const parts = [];
    /** @type {THREE.Mesh[]} */
    let selected = [];
    let activeSystem = null;

    const canonical = (mesh) => sanitize(mesh.userData.name || mesh.name);
    const infoFor = (mesh) => infoByCanonical[canonical(mesh)];

    const prettify = (mesh) => {
      const info = infoFor(mesh);
      if (info && info.title) return info.title;
      if (mesh.userData.fallback) return mesh.userData.fallback.title;
      return STRUCTURAL_TITLE;
    };

    const describe = (mesh) => {
      const info = infoFor(mesh);
      if (info && info.description) return info.description;
      if (mesh.userData.fallback) return mesh.userData.fallback.description;
      return STRUCTURAL_TEXT;
    };

    const updatePanel = (title, description) => {
      titleEl.textContent = title;
      descriptionEl.textContent = description;
      chipRow.querySelectorAll('button').forEach((button) => {
        button.classList.toggle('is-active', button.dataset.key === activeSystem);
      });
    };

    // Solid highlight material — the model's baked carbon materials are too dark
    // for a subtle tint to read, so selection swaps to an unmistakable brand blue.
    const highlightMaterial = new THREE.MeshStandardMaterial({
      color: 0x3a62b4,
      emissive: 0x16244c,
      emissiveIntensity: 0.45,
      metalness: 0.15,
      roughness: 0.4,
    });

    const highlight = (meshes) => {
      for (const mesh of selected) mesh.material = mesh.userData.originalMaterial;
      for (const mesh of meshes) mesh.material = highlightMaterial;
      selected = meshes;
    };

    const selectNone = () => {
      activeSystem = null;
      highlight([]);
      updatePanel(DEFAULT_TITLE, DEFAULT_TEXT);
    };

    const selectPart = (mesh) => {
      if (!mesh || (selected.length === 1 && selected[0] === mesh)) {
        selectNone();
        return;
      }
      activeSystem = null;
      highlight([mesh]);
      updatePanel(prettify(mesh), describe(mesh));
    };

    const selectSystem = (key) => {
      if (activeSystem === key) {
        selectNone();
        return;
      }
      const system = SYSTEMS[key];
      const members = new Set(system.parts.map(sanitize));
      activeSystem = key;
      highlight(parts.filter((mesh) => members.has(canonical(mesh))));
      updatePanel(system.label, system.description);
    };

    const loader = new GLTFLoader();
    loader.load(
      '/models/ligmax.glb',
      (gltf) => {
        const root = gltf.scene;

        // Centre the model on the origin
        const box = new THREE.Box3().setFromObject(root);
        const center = box.getCenter(new THREE.Vector3());
        const size = box.getSize(new THREE.Vector3());
        root.position.sub(center);
        scene.add(root);

        root.traverse((object) => {
          if (object.isMesh) {
            object.userData.originalMaterial = object.material;
            parts.push(object);
          }
        });

        // Unnamed parts inherit a short label from the hull region they sit in.
        const REGIONS = [
          {
            name: 'Body1.010',
            title: 'Right side hull — section',
            description:
              'Part of the starboard (right) outrigger — one of the two side hulls that give the trimaran its wide, stable stance.',
          },
          {
            name: 'Body1.017',
            title: 'Left side hull — section',
            description:
              'Part of the port (left) outrigger — one of the two side hulls that give the trimaran its wide, stable stance.',
          },
          {
            name: 'Body1.003',
            title: 'Main hull — section',
            description:
              'Part of the central hull, which carries the propulsion system, the sliding battery and the main electronics.',
          },
        ];
        const regionBoxes = [];
        for (const region of REGIONS) {
          const regionMesh = parts.find((mesh) => canonical(mesh) === sanitize(region.name));
          if (regionMesh) {
            regionBoxes.push({
              ...region,
              box: new THREE.Box3().setFromObject(regionMesh).expandByScalar(0.03),
            });
          }
        }
        const partCenter = new THREE.Vector3();
        for (const mesh of parts) {
          const info = infoFor(mesh);
          if (info && info.title) continue;
          new THREE.Box3().setFromObject(mesh).getCenter(partCenter);
          const region = regionBoxes.find((r) => r.box.containsPoint(partCenter));
          if (region) {
            mesh.userData.fallback = { title: region.title, description: region.description };
          }
        }

        // Frame the camera
        const maxDim = Math.max(size.x, size.y, size.z);
        const distance = (maxDim / (2 * Math.tan((camera.fov * Math.PI) / 360))) * 1.25;
        camera.position.setFromSphericalCoords(
          distance,
          THREE.MathUtils.degToRad(68),
          THREE.MathUtils.degToRad(-38)
        );
        camera.near = distance / 100;
        camera.far = distance * 20;
        camera.updateProjectionMatrix();
        controls.minDistance = distance * 0.35;
        controls.maxDistance = distance * 3;
        controls.saveState();

        // Build the system chips
        for (const [key, system] of Object.entries(SYSTEMS)) {
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'chip';
          button.dataset.key = key;
          button.textContent = system.label;
          button.addEventListener('click', () => selectSystem(key));
          chipRow.appendChild(button);
        }

        // Debug/QA: log every component and how it resolved, and expose it on window.
        const partTable = parts.map((mesh) => ({
          gltfName: mesh.userData.name || mesh.name,
          threeName: mesh.name,
          title: prettify(mesh),
          systems: Object.entries(SYSTEMS)
            .filter(([, system]) => system.parts.some((p) => sanitize(p) === canonical(mesh)))
            .map(([key]) => key)
            .join(', '),
        }));
        console.table(partTable);
        window.__ligmax = {
          parts: partTable,
          systems: Object.fromEntries(
            Object.entries(SYSTEMS).map(([key, system]) => {
              const members = new Set(system.parts.map(sanitize));
              const resolved = parts.filter((mesh) => members.has(canonical(mesh))).length;
              return [key, { listed: system.parts.length, resolved }];
            })
          ),
        };

        statusEl.remove();
      },
      undefined,
      () => {
        statusEl.textContent = 'The 3D model could not be loaded.';
      }
    );

    // Picking — only when the pointer has not been dragged
    const raycaster = new THREE.Raycaster();
    const pointer = new THREE.Vector2();
    let downX = 0;
    let downY = 0;

    const pick = (event) => {
      const rect = canvas.getBoundingClientRect();
      pointer.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
      pointer.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
      raycaster.setFromCamera(pointer, camera);
      const hit = raycaster.intersectObjects(parts, false)[0];
      return hit ? hit.object : null;
    };

    canvas.addEventListener('pointerdown', (event) => {
      downX = event.clientX;
      downY = event.clientY;
    });

    canvas.addEventListener('pointerup', (event) => {
      if (Math.hypot(event.clientX - downX, event.clientY - downY) > 6) return;
      selectPart(pick(event));
    });

    canvas.addEventListener('pointermove', (event) => {
      if (event.buttons) return;
      canvas.style.cursor = pick(event) ? 'pointer' : 'grab';
    });

    resetBtn?.addEventListener('click', () => controls.reset());

    // Sizing
    const resize = () => {
      const width = stage.clientWidth;
      const height = stage.clientHeight;
      renderer.setSize(width, height, false);
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
    };
    new ResizeObserver(resize).observe(stage);
    resize();

    renderer.setAnimationLoop(() => {
      controls.update();
      renderer.render(scene, camera);
    });
  }
</script>

<style>
  .explorer {
    display: grid;
    grid-template-columns: minmax(0, 8fr) minmax(0, 4fr);
    gap: clamp(1.25rem, 3vw, 2rem);
    align-items: stretch;
  }

  .stage-card {
    background: linear-gradient(180deg, #fdfdfe 0%, #e9eef7 100%);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
  }

  .stage {
    position: relative;
    flex: 1;
    min-height: clamp(24rem, 62vh, 40rem);
    border-radius: calc(var(--radius) - 4px);
    overflow: hidden;
  }

  .stage canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    touch-action: none;
    cursor: grab;
  }

  .stage-overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 0.95rem;
    color: var(--muted);
    background: transparent;
    pointer-events: none;
  }

  .stage-reset {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.9);
    color: var(--ink);
    font: inherit;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
  }

  .stage-reset:hover {
    border-color: var(--brand-500);
    color: var(--brand-600);
  }

  .stage-hint {
    margin: 0.55rem 0 0.25rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .panel {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    padding: clamp(1.4rem, 3vw, 1.9rem);
    align-self: start;
  }

  .panel-eyebrow {
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brand-500);
  }

  .panel-title {
    font-size: 1.35rem;
    margin: 0.5rem 0 0.7rem;
    overflow-wrap: anywhere;
  }

  .panel-description {
    font-size: 0.96rem;
    margin: 0;
  }

  .panel-divider {
    height: 1px;
    background: var(--line);
    margin: 1.3rem 0 1.1rem;
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .chip-row :global(.chip) {
    font: inherit;
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--body);
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.36rem 0.85rem;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease, background-color 0.15s ease;
  }

  .chip-row :global(.chip:hover) {
    border-color: var(--brand-500);
    color: var(--brand-600);
  }

  .chip-row :global(.chip.is-active) {
    background: var(--brand);
    border-color: var(--brand);
    color: #fff;
  }

  .panel-list-heading {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.7rem;
  }

  @media (max-width: 980px) {
    .explorer {
      grid-template-columns: 1fr;
    }

    .stage {
      min-height: clamp(20rem, 55vh, 30rem);
    }
  }
</style>
