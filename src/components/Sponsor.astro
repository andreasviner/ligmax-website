---
const email = 'andreas.e.lindeman@gmail.com';

const benefits = [
  'Brand placement on the vessel, team apparel and this site',
  'Visibility at an international competition followed by Trondheim’s maritime-autonomy cluster',
  'Direct access to motivated NTNU engineering students',
  'Support for hardware, on-water testing and the 2026 campaign',
];
---

<section class="sponsor section" id="contact">
  <div class="container sponsor-grid">
    <div class="sponsor-copy" data-reveal>
      <span class="eyebrow eyebrow--light">Sponsor &amp; contact</span>
      <h2>Partner with Ligmax</h2>
      <p>
        Ligmax has been entirely self-funded to date: every component on the vessel was bought, built and
        tested on our own budget. Partnering with us puts your brand behind a hands-on engineering campaign
        and helps carry the platform through competition season and beyond.
      </p>
      <ul class="benefit-list">
        {benefits.map((benefit) => (
          <li>
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4.5 12.5l5 5L19.5 7" />
            </svg>
            <span>{benefit}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="contact-card" data-reveal>
      <h3>Get in touch</h3>
      <p>
        Whether you are interested in sponsoring the team, collaborating technically, or simply want to know
        more about the project, we would like to hear from you.
      </p>
      <div class="contact-actions">
        <a class="btn btn--primary" href={`mailto:${email}?subject=Sponsorship%20enquiry%20%E2%80%94%20Team%20Ligmax`}>
          Become a sponsor
        </a>
        <a class="btn btn--outline" href={`mailto:${email}?subject=Enquiry%20%E2%80%94%20Team%20Ligmax`}>
          Contact the team
        </a>
      </div>
      <dl class="contact-details">
        <div>
          <dt>Email</dt>
          <dd><a href={`mailto:${email}`}>{email}</a></dd>
        </div>
        <div>
          <dt>Based at</dt>
          <dd>NTNU Department of Electronic Systems, Trondheim, Norway</dd>
        </div>
      </dl>
    </div>
  </div>
</section>

<style>
  .sponsor {
    background:
      radial-gradient(48rem 26rem at 12% 8%, rgba(79, 127, 206, 0.18), transparent 62%),
      linear-gradient(180deg, var(--navy-900), var(--navy-950));
    color: #c3cee6;
  }

  .sponsor-grid {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .eyebrow--light {
    color: #9db8e8;
  }

  .sponsor-copy h2 {
    color: #fff;
    font-size: clamp(1.7rem, 3.4vw, 2.35rem);
  }

  .sponsor-copy p {
    max-width: 58ch;
    font-size: 1.05rem;
  }

  .benefit-list {
    list-style: none;
    padding: 0;
    margin: 1.6rem 0 0;
    display: grid;
    gap: 0.85rem;
  }

  .benefit-list li {
    display: flex;
    gap: 0.7rem;
    align-items: baseline;
    font-size: 1.0rem;
  }

  .benefit-list svg {
    flex: none;
    color: #7ea4e0;
    transform: translateY(2px);
  }

  .contact-card {
    background: #fff;
    color: var(--body);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    padding: clamp(1.6rem, 3vw, 2.2rem);
  }

  .contact-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.6rem;
  }

  .contact-card > p {
    font-size: 0.98rem;
  }

  .contact-actions {
    display: grid;
    gap: 0.7rem;
    margin: 1.4rem 0 1.6rem;
  }

  .contact-details {
    margin: 0;
    border-top: 1px solid var(--line);
    padding-top: 1.2rem;
    display: grid;
    gap: 0.9rem;
  }

  .contact-details dt {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .contact-details dd {
    margin: 0.1rem 0 0;
    font-size: 0.97rem;
    color: var(--ink);
  }

  @media (max-width: 900px) {
    .sponsor-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
