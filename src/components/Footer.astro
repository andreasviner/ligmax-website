---
import logo from '../assets/ligmax-logo.svg';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img src={logo.src} alt="Ligmax" width="132" height="65" />
      <p>
        Autonomous surface vessel team<br />
        NTNU Department of Electronic Systems<br />
        Trondheim, Norway
      </p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <h3>Site</h3>
      <ul>
        <li><a href="/#vessel">The Vessel</a></li>
        <li><a href="/vessel">3D Explorer</a></li>
        <li><a href="/build">The Build</a></li>
        <li><a href="/#technology">Technology</a></li>
        <li><a href="/#njord">Njord 2026</a></li>
        <li><a href="/#team">Team</a></li>
        <li><a href="/#contact">Sponsor &amp; contact</a></li>
      </ul>
    </nav>

    <div class="footer-nav">
      <h3>Resources</h3>
      <ul>
        <li><a href="/docs/ligmax-technical-report-2026.pdf" target="_blank" rel="noopener">Technical report (PDF)</a></li>
        <li><a href="https://www.njordchallenge.com/" target="_blank" rel="noopener">Njord Challenge</a></li>
        <li><a href="https://www.ntnu.edu/ies" target="_blank" rel="noopener">NTNU Elsys</a></li>
        <li><a href="mailto:andreas.e.lindeman@gmail.com">andreas.e.lindeman@gmail.com</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-base">
    <p>&copy; {year} Team Ligmax. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy-950);
    color: #93a5cd;
    padding-top: 3.5rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 3fr) minmax(0, 3fr);
    gap: 2.5rem;
    padding-bottom: 2.5rem;
  }

  .footer-brand img {
    height: 2rem;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.92;
  }

  .footer-brand p {
    margin: 1.1rem 0 0;
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .footer-nav h3 {
    color: #fff;
    font-size: 0.82rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    margin-bottom: 0.9rem;
  }

  .footer-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
  }

  .footer-nav a {
    color: #b9c6e4;
    font-size: 0.94rem;
  }

  .footer-nav a:hover {
    color: #fff;
  }

  .footer-base {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-block: 1.4rem;
  }

  .footer-base p {
    margin: 0;
    font-size: 0.85rem;
  }

  @media (max-width: 820px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
